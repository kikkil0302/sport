generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// GDPR data minimisation: only what authentication strictly requires.
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime   @default(now())
  sessions     Session[]
  workouts     Workout[]
  exercises    Exercise[]
  bodyWeights  BodyWeightEntry[]
  programs     Program[]
}

// Reusable workout template; starting it copies its sets into a new Workout.
model Program {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime     @default(now())
  sets        ProgramSet[]
}

model ProgramSet {
  id         String   @id @default(cuid())
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  reps       Int
  weightKg   Float?
}

// Body-weight log for progression stats.
model BodyWeightEntry {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  measuredAt DateTime
  weightKg   Float

  @@index([userId, measuredAt])
}

// Exercise catalog: userId null = built-in, otherwise user-created.
model Exercise {
  id          String       @id @default(cuid())
  name        String
  muscleGroup String
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets        WorkoutSet[]
  programSets ProgramSet[]

  @@unique([name, userId])
}

// A logged training session.
model Workout {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  performedAt DateTime     @default(now())
  notes       String?
  sets        WorkoutSet[]

  @@index([userId, performedAt])
}

model WorkoutSet {
  id         String   @id @default(cuid())
  workoutId  String
  workout    Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  order      Int
  reps       Int
  // Null for bodyweight-only sets.
  weightKg   Float?

  @@index([exerciseId])
}

model Session {
  id        String   @id @default(cuid())
  // SHA-256 of the session token; the raw token only lives in the user's cookie.
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
}
